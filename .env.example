# Gemini API keys (tạo trong Google AI Studio)
# Key có thể bắt đầu bằng `AQ...` hoặc format khác; cứ dán nguyên chuỗi.
# Có thể dùng 1 key:
GEMINI_API_KEY=AQ_your_gemini_key_here
#
# Hoặc nhiều key để xoay vòng khi rate limit:
# GEMINI_API_KEYS=AQ_key_1,AQ_key_2,AQ_key_3
#
# Model mặc định nếu không set: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash
#
# Model dự phòng khi model chính trả 503:
# GEMINI_FALLBACK_MODELS=gemini-2.5-flash
#
# Tăng nếu muốn câu trả lời dài hơn trước khi bị cắt:
# GEMINI_MAX_OUTPUT_TOKENS=4096
# Số lần tự xin "viết tiếp" nếu model bị ngắt giữa chừng:
# GEMINI_MAX_CONTINUATIONS=2
